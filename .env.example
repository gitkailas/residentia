# Local Postgres connection for development
DATABASE_URL=postgres://residentia_user:ResidentiaPass123!@localhost:5432/residentia
JWT_SECRET=replace-with-a-strong-secret

# Razorpay payment gateway (test mode — no real money)
# Sign up at https://dashboard.razorpay.com/signup → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

